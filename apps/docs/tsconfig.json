{
  "extends": "@workspace/typescript-config/nextjs.json",
  "compilerOptions": {
    // App project (no library emit). The shared base sets declaration:true, which trips TS2742
    // ("inferred type cannot be named") on source.config.ts under bun's nested node_modules.
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@/*": ["./*"],
      "collections/*": ["./.source/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.mjs",
    "source.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
