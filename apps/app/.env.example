# Supabase — copy to .env.local and fill in from your project's API settings.
# Until these are set, the app runs on mock data (no auth enforcement).
NEXT_PUBLIC_SUPABASE_URL=
# Publishable key (sb_publishable_…) — safe for the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only secret key (sb_secret_…). Never prefix with NEXT_PUBLIC_ (that
# would ship it to the browser). Used for admin tasks like inviting users and
# the lead-ingestion endpoint.
SUPABASE_SECRET_KEY=
