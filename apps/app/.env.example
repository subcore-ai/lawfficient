# Supabase — copy to .env.local and fill in from your project's API settings.
# Until these are set, the app runs on mock data (no auth enforcement).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never prefix with NEXT_PUBLIC_ (that would ship it to the browser).
# Used for admin tasks like inviting users and the lead-ingestion endpoint.
SUPABASE_SERVICE_ROLE_KEY=
